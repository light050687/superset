# ──────────────────────────────────────────────────────────────────────
# docker/.env-local — локальный override переменных Docker Compose.
# Скопируй из .env-local.example:
#   cp docker/.env-local.example docker/.env-local
#
# Этот файл НЕ коммитится (включён в .gitignore через docker/*local*).
# Здесь храним machine-specific настройки: AI backend URL, корп-CA,
# порты Docker Desktop, etc.
# ──────────────────────────────────────────────────────────────────────

# ─── AI backend (ai-analytics) ──────────────────────────────────────────
# URL Go-сервиса с LLM-pipeline. По дефолту — корп-сервер Samberi.
# Используется webpack DefinePlugin при build (AI_BACKEND_URL прокидывается
# в bundle через process.env.AI_BACKEND_URL).
#
# AI_BACKEND_URL=http://dataru-saod-llm02-vm.samberi.com:8080

# ─── Корпоративный CA сертификат ────────────────────────────────────────
# Если ваша сеть с MITM-прокси (Bluecoat/Zscaler/Forcepoint) — base64'ом
# экспортированный корп-CA подкладывается в Docker trust store при build.
# См. docs/setup.md → Корп-сеть для инструкций.
#
# Получить значение:
#   Linux/Mac:   base64 -w0 corp-ca.pem
#   PowerShell:  [Convert]::ToBase64String([IO.File]::ReadAllBytes('corp-ca.pem'))
#
# CORP_CA_CERT_B64=

# ─── Загрузка примеров (CSV из GitHub) ──────────────────────────────────
# yes — superset-init скачивает sample-данные с GitHub (требует доступ
# в интернет без MITM или с правильно подложенным CORP_CA_CERT_B64).
# no — пропустить (рекомендуется для корп-сетей и быстрого старта).
#
# SUPERSET_LOAD_EXAMPLES=no

# ─── Уровень логирования ────────────────────────────────────────────────
# debug | info | warning | error
#
# SUPERSET_LOG_LEVEL=info

# ─── Translations ──────────────────────────────────────────────────────
# true — pybabel compile при build (нужно если правишь .po файлы).
# false (default) — используются предкомпилированные .mo/.json
# (русский в гите, остальные языки нужно собирать руками).
#
# BUILD_TRANSLATIONS=false

# ─── Build target ──────────────────────────────────────────────────────
# dev — devmode с volume-mount исходников, hot reload (default).
# lean — production-like, без dev-инструментов.
#
# SUPERSET_BUILD_TARGET=dev

# ─── Headless browser для thumbnails / alert-reports ───────────────────
# true — Chromium встроен в superset image (большой размер).
# false (default) — без screenshot-возможностей.
#
# INCLUDE_CHROMIUM=false
# INCLUDE_FIREFOX=false
