# Универсальные настройки npm для superset-frontend.
# Эти переменные безопасны для всех окружений (dev / CI / prod).
# Корп-сетевые workarounds (strict-ssl) — через build-arg в Dockerfile,
# не здесь.

# Не качать Chromium при npm install puppeteer (он используется только
# для скриншотов alert-reports, для нашей разработки не нужен).
puppeteer_skip_download=true
puppeteer_skip_chromium_download=true

# Совместимость с старыми peer-dependencies — multiple Superset плагины
# требуют react@17, новые packages — react@18; legacy-peer-deps позволяет
# их сосуществовать.
legacy-peer-deps=true
